{% doc %}
  @prompt
    image d'un coté texte de l'autre avec la possibilité d'inverser 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-text-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-image-text__container-{{ ai_gen_id }} {
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    gap: {{ block.settings.gap }}px;
    flex-direction: {% if block.settings.layout == 'image_left' %}row{% else %}row-reverse{% endif %};
  }

  .ai-image-text__image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    position: relative;
  }

  .ai-image-text__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-text__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-image-text__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-text__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-text__content-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-image-text__heading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-image-text__text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-image-text__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
    align-self: flex-start;
  }

  .ai-image-text__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-text__container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-image-text__image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 auto;
      width: 100%;
    }

    .ai-image-text__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-image-text__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<image-text-block-{{ ai_gen_id }}
  class="ai-image-text-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-text__container-{{ ai_gen_id }}">
    <div class="ai-image-text__image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-image-text__image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-image-text__image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-text__empty-state-{{ ai_gen_id }}">
            Ajoutez une image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-image-text__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-image-text__heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-image-text__text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-image-text__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</image-text-block-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageTextBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('image-text-block-{{ ai_gen_id }}', ImageTextBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Image et texte",
  "settings": [
    {
      "type": "header",
      "content": "Disposition"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Position de l'image",
      "options": [
        {
          "value": "image_left",
          "label": "Image à gauche"
        },
        {
          "value": "image_right",
          "label": "Image à droite"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Largeur de l'image",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Alignement vertical",
      "options": [
        {
          "value": "flex-start",
          "label": "Haut"
        },
        {
          "value": "center",
          "label": "Centre"
        },
        {
          "value": "flex-end",
          "label": "Bas"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espacement (desktop)",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Espacement (mobile)",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Titre",
      "default": "<p>Titre de la section</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Texte",
      "default": "<p>Ajoutez votre texte descriptif ici. Expliquez les avantages de votre produit ou service.</p>"
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Espacement du contenu",
      "min": 10,
      "max": 40,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Bouton"
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "Texte du bouton",
      "default": "En savoir plus"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Lien du bouton"
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "Padding vertical",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "Padding horizontal",
      "min": 16,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Fond du bouton",
      "default": "#2c2c2c"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Fond du bouton (survol)",
      "default": "#8b7355"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Texte du bouton",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille du titre",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Taille du texte",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "Taille du texte du bouton",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    }
  ],
  "presets": [
    {
      "name": "Image et texte"
    }
  ]
}
{% endschema %}
