{% doc %}
  @prompt
    peux generer une section avec les logo de paiement accepté 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-payment-icons-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.vertical_padding }}px {{ block.settings.horizontal_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-payment-icons__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.alignment }};
    gap: {{ block.settings.spacing_between_elements }}px;
  }

  .ai-payment-icons__title-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.alignment }};
  }

  .ai-payment-icons__list-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: {{ block.settings.icon_spacing }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
  }

  .ai-payment-icons__icon-{{ ai_gen_id }} {
    height: {{ block.settings.icon_size }}px;
    width: auto;
    opacity: {{ block.settings.icon_opacity }};
    transition: opacity 0.2s ease;
  }

  .ai-payment-icons__icon-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-payment-icons__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }

    .ai-payment-icons__icon-{{ ai_gen_id }} {
      height: calc({{ block.settings.icon_size }}px * 0.8);
    }
  }
{% endstyle %}

<payment-icons-{{ ai_gen_id }}
  class="ai-payment-icons-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-payment-icons__container-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h3 class="ai-payment-icons__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
    {% endif %}

