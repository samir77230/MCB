{% doc %}
  @prompt
    j'aimerai avoir un séparateur qui viendrait séparé par une petite bande blanche deux section 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-section-divider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-section-divider__line-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
    margin: 0 auto;
    border-radius: {{ block.settings.border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-section-divider__line-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div
  class="ai-section-divider-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-section-divider__line-{{ ai_gen_id }}"></div>
</div>

{% schema %}
{
  "name": "Séparateur de section",
  "settings": [
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "divider_height",
      "label": "Épaisseur",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Couleur",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largeur sur ordinateur",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Espace au-dessus",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Espace en-dessous",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Séparateur de section"
    }
  ]
}
{% endschema %}
